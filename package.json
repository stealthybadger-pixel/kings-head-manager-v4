{
  "name": "kings-head-manager-v4",
  "private": true,
  "version": "4.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest run",
    "scrape:login": "npx tsx scripts/reconcile_prices.ts --setup",
    "scrape:check": "npx tsx scripts/reconcile_prices.ts",
    "scrape:update": "npx tsx scripts/reconcile_prices.ts --write",
    "scrape:menu-check": "npx tsx scripts/reconcile_active_menu_prices.ts",
    "scrape:menu-update": "npx tsx scripts/reconcile_active_menu_prices.ts --write",
    "price-sync:server": "node scripts/priceSyncServer.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.28.4",
    "@tanstack/react-virtual": "^3.14.5",
    "firebase": "^10.8.0",
    "lucide-react": "^0.363.0",
    "pdfjs-dist": "^4.2.67",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-basic-ssl": "^1.2.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "firebase-admin": "^14.1.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.6",
    "vitest": "^4.1.10"
  }
}
