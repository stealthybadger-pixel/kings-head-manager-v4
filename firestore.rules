rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isManager() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // User profiles (email, displayName, role). Any signed-in user can read
    // the list (needed for the Team screen and for resolving your own
    // role on login). Only managers can create/edit/delete other users'
    // profiles — new accounts are created from the Team screen by a
    // manager, who then writes this doc under their own session.
    //
    // Known v1 limitation: a signed-in user with NO existing profile doc
    // may create their own doc (this is the one-time bootstrap path for
    // the very first manager account, added manually in the Firebase
    // console before any Team-created accounts exist). In practice this
    // only matters if someone creates a stray Firebase Auth account
    // outside the app's Team screen, since there's no self-signup UI.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isManager() || request.auth.uid == uid);
      allow update, delete: if isManager();
    }

    // Master data — recipes, ingredients, dishes, and everything that
    // feeds costing/menu structure. Any signed-in team member can read
    // (staff need to browse/scale recipes, look up allergens, etc.) but
    // only managers can create/edit/delete, so staff can't silently
    // change a recipe formulation or dish pricing.
    match /ingredients/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /recipes/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /dishes/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /container_profiles/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /suppliers/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /supplierProducts/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    match /scrapeLog/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }
    // Floor plan equipment boxes (position/name/range) — editing the
    // layout is manager-only in the UI ("Edit Layout" mode); enforced
    // here too so staff can't reposition/rename/delete equipment, only
    // record readings against it (see equipment_temp_checks below).
    match /equipment/{id} {
      allow read: if isSignedIn();
      allow write: if isManager();
    }

    // Day-to-day operational records — any signed-in team member (staff
    // or manager) can log these: stock counts/wastage, stocktakes, and
    // food/equipment temperature checks. This is where staff actually
    // do their job day to day, so it stays open to the whole team.
    match /stock_movements/{id} {
      allow read, write: if isSignedIn();
    }
    match /stocktake_reports/{id} {
      allow read, write: if isSignedIn();
    }
    // Single in-progress stocktake draft (paused, not yet committed) — same
    // access tier as stocktake_reports since it's the same operational flow.
    match /stocktake_drafts/{id} {
      allow read, write: if isSignedIn();
    }
    match /food_temp_checks/{id} {
      allow read, write: if isSignedIn();
    }
    match /equipment_temp_checks/{id} {
      allow read, write: if isSignedIn();
    }
  }
}
